# Salin file ini menjadi ".env" lalu isi nilainya sendiri.
# JANGAN commit file ".env" ke GitHub.

# Username & password admin dashboard
ADMIN_USER=admin
ADMIN_PASS=kaligayam2026

# Kunci rahasia untuk token login (isi string acak yang panjang)
JWT_SECRET=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# Ambil dari Supabase: Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=isi-dengan-service_role-key-dari-supabase

# Port server (Replit/Vercel akan otomatis override ini, aman dibiarkan)
PORT=3000
